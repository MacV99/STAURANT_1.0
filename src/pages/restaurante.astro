---
import Layout1 from "../layouts/Layout1.astro";
import DishForm from "../components/DishForm.astro";
import RestaurantForm from "../components/RestaurantForm.astro";
import ConfirmDialog from "../components/ConfirmDialog.astro";
---

<Layout1 title="Restaurante · STAURANT">
  <div class="detail-page">
    <a id="back-link" href="/" class="back-link">
      <i class="bi bi-arrow-left"></i> Volver
    </a>

    <div id="restaurant-header" class="restaurant-header"></div>

    <div class="dishes-section">
      <div class="dishes-top">
        <h2 class="dishes-title">Platos</h2>
        <button id="btn-add-dish" class="boton">
          <i class="bi bi-plus-lg"></i> Agregar plato
        </button>
      </div>

      <div class="sort-bar">
        <span class="sort-label">Ordenar</span>
        <div class="sort-pills">
          <button class="sort-pill" data-field="rating"><i class="bi bi-arrow-down-up"></i> Rating</button>
          <button class="sort-pill" data-field="name"><i class="bi bi-arrow-down-up"></i> Nombre</button>
          <button class="sort-pill" data-field="date"><i class="bi bi-arrow-down-up"></i> Fecha</button>
        </div>
      </div>

      <div id="dishes-list"></div>
    </div>
  </div>

  <DishForm />
  <RestaurantForm />
  <ConfirmDialog />
</Layout1>

<style>
  .detail-page {
    width: 100%;
    max-width: 760px;
    padding: 20px 16px 80px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--clr-primary);
    letter-spacing: 1px;
    width: fit-content;
    padding: 6px 0;
    transition: var(--transition);
  }

  .restaurant-header {
    width: 100%;
  }

  .dishes-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .dishes-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  #btn-add-dish {
    text-transform: none;
    letter-spacing: 0.5px;
    background: var(--clr-primary);
    color: white;
    border-color: var(--clr-primary);
    font-size: 0.85rem;
    padding: 9px 16px;
  }

  .dishes-title {
    font-size: 1rem;
    letter-spacing: 2px;
    color: var(--clr-dark);
  }

  #dishes-list {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  @media (hover: hover) {
    .back-link:hover {
      color: var(--clr-dark);
    }
  }

  @media (min-width: 768px) {
    .detail-page {
      padding: 28px 24px 80px;
    }
  }
</style>

<script>
  import { supabase } from "../lib/supabase.ts";
  import {
    initCache, isCacheLoaded,
    getRestaurants, getDishesByRestaurant,
    deleteDish, deleteRestaurant, getRestaurantAverage,
    markAsVisited, markAsPending, escapeHtml,
  } from "../lib/data.ts";
  import type { Restaurant } from "../lib/data.ts";
  import { renderDishCard, getRatingBadgeHTML, emit } from "../scripts/store.ts";

  // ─── Sort state (persiste en módulo entre navegaciones) ────────────────────

  type SortField = "name" | "rating" | "date";
  type SortDir   = "asc" | "desc";
  const SORT_KEY = "staurant_sort_d";

  function getSortState(): { field: SortField; dir: SortDir } {
    try { return JSON.parse(localStorage.getItem(SORT_KEY) ?? "{}"); }
    catch { return { field: "rating", dir: "desc" }; }
  }
  function setSortState(s: { field: SortField; dir: SortDir }) {
    localStorage.setItem(SORT_KEY, JSON.stringify(s));
  }
  let dishSort = { field: "rating" as SortField, dir: "desc" as SortDir, ...getSortState() };

  function sortDishes(dishes: ReturnType<typeof getDishesByRestaurant>) {
    return [...dishes].sort((a, b) => {
      let cmp = 0;
      if (dishSort.field === "name")        cmp = a.name.localeCompare(b.name);
      else if (dishSort.field === "rating") cmp = a.rating - b.rating;
      else cmp = new Date(a.createdAt).getTime() - new Date(b.createdAt).getTime();
      return dishSort.dir === "asc" ? cmp : -cmp;
    });
  }

  // ─── Restaurante activo (nivel de módulo) ──────────────────────────────────
  // Actualizado en cada astro:page-load. Los listeners de módulo lo leen aquí.

  let currentRestaurant: Restaurant | undefined;

  // ─── Generadores de HTML (nivel módulo) ────────────────────────────────────

  function buildHeaderHTML(r: Restaurant, avg: number | null): string {
    const dishes    = getDishesByRestaurant(r.id);
    const isPending = r.status === "pending";
    return `
      <div class="rh-card">
        <div class="rh-top">
          ${getRatingBadgeHTML(avg)}
          <div class="rh-meta">
            <h1 class="rh-name">${escapeHtml(r.name)}</h1>
            <div class="rh-pills">
              ${isPending
                ? `<span class="pending-tag"><i class="bi bi-bookmark"></i> Pendiente</span>`
                : `<span class="dish-count-pill"><i class="bi bi-journal-text"></i> ${dishes.length} ${dishes.length === 1 ? "plato" : "platos"}</span>`
              }
            </div>
          </div>
          <div class="rh-actions">
            <button class="btn-edit-rh boton2" data-id="${r.id}" aria-label="Editar restaurante">
              <i class="bi bi-pencil"></i>
            </button>
            <button class="btn-delete-rh boton2" data-id="${r.id}" aria-label="Eliminar restaurante">
              <i class="bi bi-trash"></i>
            </button>
          </div>
        </div>
        ${r.notes ? `<p class="rh-notes">${escapeHtml(r.notes)}</p>` : ""}
      </div>`;
  }

  function buildDishesHTML(sorted: ReturnType<typeof getDishesByRestaurant>): string {
    if (sorted.length === 0) return `
      <div class="empty-state">
        <i class="bi bi-egg-fried"></i>
        <p>Aún no hay platos registrados.</p>
        <p class="empty-hint">Agrega el primer plato con el botón de arriba.</p>
      </div>`;
    return sorted.map(renderDishCard).join("");
  }

  // ─── Funciones de render y wiring a nivel de módulo ───────────────────────
  // Consultan el DOM en cada llamada → inocuas en páginas sin estos elementos.

  function wireHeaderEvents() {
    const headerEl = document.getElementById("restaurant-header");
    if (!headerEl || !currentRestaurant) return;
    headerEl.querySelector<HTMLButtonElement>(".btn-edit-rh")?.addEventListener("click", () => {
      (window as any).restaurantForm.open("edit", currentRestaurant!);
    });
    headerEl.querySelector<HTMLButtonElement>(".btn-delete-rh")?.addEventListener("click", () => {
      (window as any).confirmDialog.show(
        `¿Eliminar "${currentRestaurant?.name}"? Se borrarán también sus platos.`,
        () => { deleteRestaurant(currentRestaurant!.id); window.location.href = "/"; }
      );
    });
  }

  function wireDishActions(dishes: ReturnType<typeof getDishesByRestaurant>) {
    const dishesListEl = document.getElementById("dishes-list");
    if (!dishesListEl || !currentRestaurant) return;
    dishesListEl.querySelectorAll<HTMLButtonElement>(".btn-edit-dish").forEach(btn => {
      btn.addEventListener("click", () => {
        const dish = dishes.find(d => d.id === btn.dataset.id);
        if (dish) (window as any).dishForm.open("edit", currentRestaurant!.id, dish);
      });
    });
    dishesListEl.querySelectorAll<HTMLButtonElement>(".btn-delete-dish").forEach(btn => {
      btn.addEventListener("click", () => {
        const dish = dishes.find(d => d.id === btn.dataset.id);
        (window as any).confirmDialog.show(
          `¿Eliminar el plato "${dish?.name}"?`,
          () => { deleteDish(btn.dataset.id!); emit("dish:deleted", btn.dataset.id); }
        );
      });
    });
  }

  function rerenderRestaurantePage() {
    const headerEl    = document.getElementById("restaurant-header");
    const dishesListEl = document.getElementById("dishes-list");
    const sortBarEl   = document.querySelector<HTMLElement>(".sort-bar");
    if (!headerEl || !dishesListEl || !currentRestaurant) return;

    const avg    = getRestaurantAverage(currentRestaurant.id);
    const sorted = sortDishes(getDishesByRestaurant(currentRestaurant.id));

    headerEl.innerHTML    = buildHeaderHTML(currentRestaurant, avg);
    if (sortBarEl) sortBarEl.hidden = sorted.length < 2;
    dishesListEl.innerHTML = buildDishesHTML(sorted);

    wireHeaderEvents();
    if (sorted.length > 0) wireDishActions(sorted);
  }

  // ─── Listeners permanentes a nivel de módulo ──────────────────────────────

  document.addEventListener("dish:created", () => {
    if (!currentRestaurant) return;
    try {
      if (currentRestaurant.status === "pending") {
        const updated = markAsVisited(currentRestaurant.id);
        if (updated) {
          currentRestaurant = updated;
          // Actualizar backLink para que "Volver" lleve a visitados
          const bl = document.getElementById("back-link") as HTMLAnchorElement | null;
          if (bl) bl.href = "/?tab=visitados";
          emit("restaurant:visited", updated);
        }
      }
    } catch (err) {
      console.error("[dish:created] markAsVisited error:", err);
    }
    rerenderRestaurantePage();
  });

  document.addEventListener("dish:updated",  () => rerenderRestaurantePage());
  document.addEventListener("dish:deleted", () => {
    if (currentRestaurant?.status === "visited") {
      const remaining = getDishesByRestaurant(currentRestaurant.id);
      if (remaining.length === 0) {
        const updated = markAsPending(currentRestaurant.id);
        if (updated) {
          currentRestaurant = updated;
          const bl = document.getElementById("back-link") as HTMLAnchorElement | null;
          if (bl) bl.href = "/?tab=pendientes";
          emit("restaurant:updated", updated);
        }
      }
    }
    rerenderRestaurantePage();
  });

  document.addEventListener("restaurant:updated", (e) => {
    try {
      const updated = (e as CustomEvent).detail as Restaurant;
      if (updated?.id === currentRestaurant?.id) currentRestaurant = updated;
    } catch (err) {
      console.error("[restaurant:updated] error:", err);
    }
    rerenderRestaurantePage();
  });

  // ─── PRE-RENDER en astro:after-swap ────────────────────────────────────────

  document.addEventListener("astro:after-swap", () => {
    const headerEl = document.getElementById("restaurant-header");
    if (!headerEl || !isCacheLoaded()) return;

    const id = new URLSearchParams(window.location.search).get("id") ?? "";
    const restaurant = getRestaurants().find(r => r.id === id);
    if (!restaurant) return;

    const avg    = getRestaurantAverage(restaurant.id);
    const sorted = sortDishes(getDishesByRestaurant(restaurant.id));

    headerEl.innerHTML = buildHeaderHTML(restaurant, avg);

    const dishesListEl = document.getElementById("dishes-list");
    const sortBarEl    = document.querySelector<HTMLElement>(".sort-bar");
    if (!dishesListEl || !sortBarEl) return;

    sortBarEl.hidden       = sorted.length < 2;
    dishesListEl.innerHTML = buildDishesHTML(sorted);
  });

  // ─── Init completo en astro:page-load ──────────────────────────────────────

  document.addEventListener("astro:page-load", async () => {
    const headerEl = document.getElementById("restaurant-header");
    if (!headerEl) return;

    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { window.location.href = "/login"; return; }
    await initCache(session.user.id);

    const id = new URLSearchParams(window.location.search).get("id") ?? "";
    currentRestaurant = getRestaurants().find(r => r.id === id);

    const backLink = document.getElementById("back-link") as HTMLAnchorElement;
    if (backLink) backLink.href = `/?tab=${currentRestaurant?.status === "pending" ? "pendientes" : "visitados"}`;
    if (!currentRestaurant) { window.location.href = "/"; return; }

    // ─── Sort UI ──────────────────────────────────────────────────────────────

    function updateDishSortUI() {
      document.querySelectorAll<HTMLButtonElement>(".sort-pill").forEach(btn => {
        const isActive = btn.dataset.field === dishSort.field;
        btn.classList.toggle("active", isActive);
        btn.querySelector("i")!.className = isActive
          ? `bi bi-arrow-${dishSort.dir === "asc" ? "up" : "down"}`
          : "bi bi-arrow-down-up";
      });
    }

    // ─── Cablear controles ────────────────────────────────────────────────────

    document.querySelectorAll<HTMLButtonElement>(".sort-pill").forEach(btn => {
      btn.onclick = () => {
        const field = btn.dataset.field as SortField;
        if (dishSort.field === field) dishSort.dir = dishSort.dir === "asc" ? "desc" : "asc";
        else { dishSort.field = field; dishSort.dir = field === "rating" ? "desc" : "asc"; }
        setSortState(dishSort);
        updateDishSortUI();
        rerenderRestaurantePage();
      };
    });

    document.getElementById("btn-add-dish")!.onclick =
      () => (window as any).dishForm.open("create", currentRestaurant!.id);

    // ─── Render inicial con event wiring ─────────────────────────────────────

    updateDishSortUI();
    rerenderRestaurantePage();
  });
</script>
