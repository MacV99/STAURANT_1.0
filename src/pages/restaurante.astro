---
import Layout1 from "../layouts/Layout1.astro";
import DishForm from "../components/DishForm.astro";
import RestaurantForm from "../components/RestaurantForm.astro";
import ConfirmDialog from "../components/ConfirmDialog.astro";
import DishCard from "../components/DishCard.astro";
import RestaurantHeader from "../components/RestaurantHeader.astro";
import SortBar from "../components/SortBar.astro";
import type { Dish, Restaurant } from "../lib/data";

const tplDish: Dish = {
  id: "",
  restaurantId: "",
  typeId: null,
  name: "...",
  rating: 5,
  notes: " ",
  createdAt: "",
};
const tplRestaurant: Restaurant = {
  id: "",
  name: "...",
  status: "visited",
  notes: " ",
  createdAt: "",
};
---

<Layout1 title="Restaurante · STAURANT">
  <div class="detail-page">
    <a id="back-link" href="/" class="back-link">
      <i class="bi bi-arrow-left"></i> Volver
    </a>

    <div id="restaurant-header" class="restaurant-header"></div>

    <div class="dishes-section">
      <div class="dishes-top">
        <h2 class="dishes-title">Platos</h2>
        <button id="btn-add-dish" class="boton">
          <i class="bi bi-plus-lg"></i> Agregar plato
        </button>
      </div>

      <div class="dish-search-wrap">
        <i class="bi bi-search-fill dish-search-icon"></i>
        <input
          id="dish-search"
          class="dish-search-input"
          type="search"
          placeholder="Buscar plato..."
          autocomplete="off"
          spellcheck="false"
        />
      </div>

      <div class="dishes-controls">
        <SortBar
          pills={[
            { field: "rating", label: "Rating" },
            { field: "name", label: "Nombre" },
            { field: "date", label: "Fecha" },
          ]}
        />
        <div class="type-filter-wrap">
          <button id="dish-type-btn" class="type-pill">
            <span class="type-pill-label">Tipo</span>
            <span id="dish-type-value" class="type-pill-value">Todos</span>
            <i class="bi bi-chevron-down"></i>
          </button>
          <div id="dish-type-dropdown" class="type-dropdown" hidden></div>
        </div>
      </div>

      <div id="dishes-list"></div>
    </div>
  </div>

  <DishForm />
  <RestaurantForm />
  <ConfirmDialog />

  <template id="tpl-dish-card">
    <DishCard dish={tplDish} typeName="..." />
  </template>

  <template id="tpl-restaurant-header">
    <RestaurantHeader restaurant={tplRestaurant} avg={5} dishCount={0} />
  </template>
</Layout1>

<style is:global>
  #dish-type-dropdown .type-option {
    padding: 8px 12px;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--clr-text);
    cursor: pointer;
    text-transform: uppercase;
    transition: background 0.1s ease;
    border-bottom: 1px solid var(--clr-border);
  }

  #dish-type-dropdown .type-option:last-child {
    border-bottom: none;
  }

  #dish-type-dropdown .type-option.is-selected {
    color: var(--clr-primary);
    font-weight: 700;
  }

  #dish-type-dropdown .type-option.is-none {
    color: var(--clr-text);
    opacity: 0.55;
    text-transform: none;
    letter-spacing: 0;
    border-bottom: 1px solid var(--clr-border);
  }

  #dish-type-dropdown .type-option.is-empty {
    color: var(--clr-text);
    opacity: 0.5;
    text-transform: none;
    letter-spacing: 0;
    font-weight: 400;
    cursor: default;
    text-align: center;
    padding: 14px;
  }

  @media (hover: hover) {
    #dish-type-dropdown .type-option:hover,
    #dish-type-dropdown .type-option:focus {
      background: var(--clr-white2);
    }
  }
</style>

<style>
  .detail-page {
    width: 100%;
    max-width: 760px;
    padding: 20px 16px 80px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--clr-primary);
    letter-spacing: 1px;
    width: fit-content;
    padding: 6px 0;
    transition: var(--transition);
  }

  .restaurant-header {
    width: 100%;
  }

  .dishes-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .dishes-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  #btn-add-dish {
    text-transform: none;
    letter-spacing: 0.5px;
    background: var(--clr-primary);
    color: var(--clr-white);
    border-color: var(--clr-primary);
    font-size: 0.85rem;
    padding: 9px 16px;
  }

  .dishes-title {
    font-size: 1rem;
    letter-spacing: 2px;
    color: var(--clr-text);
  }

  .dish-search-wrap {
    position: relative;
    width: 100%;
  }

  .dish-search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--clr-text);
    opacity: 0.4;
    font-size: 0.85rem;
    pointer-events: none;
  }

  .dish-search-input {
    width: 100%;
    padding: 9px 14px 9px 34px;
    border-radius: var(--border-radius);
    border: 1.5px solid var(--clr-border);
    background: var(--clr-white);
    font-size: 0.88rem;
    color: var(--clr-text);
    transition: border-color var(--transition);
  }

  .dish-search-input::placeholder {
    color: var(--clr-text);
    opacity: 0.5;
  }

  .dish-search-input:focus {
    outline: none;
    border-color: var(--clr-border2);
  }

  .dish-search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }

  .dishes-controls {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .type-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 5px 12px;
    border-radius: 20px;
    border: solid 1.5px var(--clr-border);
    background: transparent;
    color: var(--clr-text);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: none;
    cursor: pointer;
    transition: var(--transition);
  }

  .type-pill.active {
    background: var(--clr-primary);
    border-color: var(--clr-primary);
    color: var(--clr-white);
  }

  .type-pill-label {
    opacity: 0.5;
  }

  .type-pill-value {
    font-weight: 700;
  }

  .type-pill i {
    font-size: 0.65rem;
  }

  .type-filter-wrap {
    position: relative;
  }

  .type-dropdown {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    min-width: max-content;
    background: var(--clr-white);
    border: 1.5px solid var(--clr-border);
    border-radius: var(--border-radius);
    z-index: 200;
    max-height: 220px;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  #dishes-list {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  @media (hover: hover) {
    .back-link:hover {
      color: var(--clr-text);
    }

    .type-pill:hover {
      border-color: var(--clr-border2);
    }

  }

  @media (min-width: 768px) {
    .detail-page {
      padding: 28px 24px 80px;
    }
  }
</style>

<script>
  import { navigate } from "astro:transitions/client";
  import { supabase } from "../lib/supabase.ts";
  import {
    initCache,
    isCacheLoaded,
    getRestaurants,
    getDishesByRestaurant,
    deleteDish,
    deleteRestaurant,
    getRestaurantAverage,
    markAsVisited,
    markAsPending,
    getDishTypes,
  } from "../lib/data.ts";
  import type { Restaurant, Dish } from "../lib/data.ts";
  import { getRatingClass, emit } from "../scripts/store.ts";

  // ─── Sort state (persiste en módulo entre navegaciones) ────────────────────

  type SortField = "name" | "rating" | "date";
  type SortDir = "asc" | "desc";
  const SORT_KEY = "staurant_sort_d";

  function getSortState(): { field: SortField; dir: SortDir } {
    try {
      const saved = JSON.parse(localStorage.getItem(SORT_KEY) ?? "{}");
      return {
        field: (saved.field as SortField) ?? "rating",
        dir: (saved.dir as SortDir) ?? "desc",
      };
    } catch {
      return { field: "rating", dir: "desc" };
    }
  }
  function setSortState(s: { field: SortField; dir: SortDir }) {
    localStorage.setItem(SORT_KEY, JSON.stringify(s));
  }
  let dishSort = getSortState();

  function sortDishes(dishes: ReturnType<typeof getDishesByRestaurant>) {
    return [...dishes].sort((a, b) => {
      let cmp = 0;
      if (dishSort.field === "name") cmp = a.name.localeCompare(b.name);
      else if (dishSort.field === "rating") cmp = a.rating - b.rating;
      else
        cmp = new Date(a.createdAt).getTime() - new Date(b.createdAt).getTime();
      return dishSort.dir === "asc" ? cmp : -cmp;
    });
  }

  function getFilteredSortedDishes(restaurantId: string): Dish[] {
    let dishes = getDishesByRestaurant(restaurantId);
    if (dishSearch) {
      const q = dishSearch.toLowerCase();
      dishes = dishes.filter(
        (d) =>
          d.name.toLowerCase().includes(q) || d.notes.toLowerCase().includes(q),
      );
    }
    if (dishTypeFilter) {
      dishes = dishes.filter((d) => d.typeId === dishTypeFilter);
    }
    return sortDishes(dishes);
  }

  function updateTypeSelect() {
    const typeBtnEl = document.getElementById(
      "dish-type-btn",
    ) as HTMLButtonElement | null;
    const typeValueEl = document.getElementById(
      "dish-type-value",
    ) as HTMLElement | null;
    if (!typeBtnEl || !typeValueEl || !currentRestaurant) return;

    const allDishes = getDishesByRestaurant(currentRestaurant.id);
    const usedTypeIds = new Set(
      allDishes.map((d) => d.typeId).filter((id): id is string => !!id),
    );
    const types = getDishTypes().filter((t) => usedTypeIds.has(t.id));

    if (types.length === 0) {
      dishTypeFilter = "";
      typeBtnEl.hidden = true;
      return;
    }

    typeBtnEl.hidden = false;
    const selectedType = types.find((t) => t.id === dishTypeFilter);
    if (!selectedType) dishTypeFilter = "";

    typeValueEl.textContent = dishTypeFilter
      ? (getDishTypes().find((t) => t.id === dishTypeFilter)?.name ?? "Todos")
      : "Todos";
    typeBtnEl.classList.toggle("active", !!dishTypeFilter);
  }

  function renderDishTypeDropdown() {
    const dropdownEl = document.getElementById(
      "dish-type-dropdown",
    ) as HTMLElement | null;
    if (!dropdownEl || !currentRestaurant) return;

    const allDishes = getDishesByRestaurant(currentRestaurant.id);
    const usedTypeIds = new Set(
      allDishes.map((d) => d.typeId).filter((id): id is string => !!id),
    );
    const types = getDishTypes().filter((t) => usedTypeIds.has(t.id));

    dropdownEl.innerHTML = "";

    const noneOpt = document.createElement("div");
    noneOpt.className = "type-option is-none";
    noneOpt.textContent = "Todos los tipos";
    noneOpt.addEventListener("mousedown", (e) => e.preventDefault());
    noneOpt.addEventListener("click", () => selectDishType(null, null));
    dropdownEl.appendChild(noneOpt);

    types.forEach((t) => {
      const opt = document.createElement("div");
      opt.className =
        "type-option" + (t.id === dishTypeFilter ? " is-selected" : "");
      opt.textContent = t.name;
      opt.addEventListener("mousedown", (e) => e.preventDefault());
      opt.addEventListener("click", () => selectDishType(t.id, t.name));
      dropdownEl.appendChild(opt);
    });

    if (types.length === 0) {
      const emptyOpt = document.createElement("div");
      emptyOpt.className = "type-option is-empty";
      emptyOpt.textContent = "Sin tipos registrados";
      dropdownEl.appendChild(emptyOpt);
    }
  }

  function openDishTypeDropdown() {
    const typeBtnEl = document.getElementById(
      "dish-type-btn",
    ) as HTMLButtonElement | null;
    const dropdownEl = document.getElementById(
      "dish-type-dropdown",
    ) as HTMLElement | null;
    if (!typeBtnEl || !dropdownEl) return;

    renderDishTypeDropdown();
    dropdownEl.hidden = false;
    typeBtnEl.classList.add("is-open");
  }

  function closeDishTypeDropdown() {
    const typeBtnEl = document.getElementById(
      "dish-type-btn",
    ) as HTMLButtonElement | null;
    const dropdownEl = document.getElementById(
      "dish-type-dropdown",
    ) as HTMLElement | null;
    if (!typeBtnEl || !dropdownEl) return;

    dropdownEl.hidden = true;
    typeBtnEl.classList.remove("is-open");
  }

  function selectDishType(id: string | null, name: string | null) {
    dishTypeFilter = id ?? "";
    const typeValueEl = document.getElementById(
      "dish-type-value",
    ) as HTMLElement | null;
    const typeBtnEl = document.getElementById(
      "dish-type-btn",
    ) as HTMLButtonElement | null;

    if (typeValueEl) typeValueEl.textContent = name ?? "Todos";
    if (typeBtnEl) typeBtnEl.classList.toggle("active", !!dishTypeFilter);
    closeDishTypeDropdown();
    rerenderRestaurantePage();
  }

  // ─── Restaurante activo + filtros (nivel de módulo) ──────────────────────────
  // Actualizados en cada astro:page-load. Los listeners de módulo los leen aquí.

  let currentRestaurant: Restaurant | undefined;
  let dishSearch = "";
  let dishTypeFilter = "";

  // ─── Generadores de HTML (nivel módulo) ────────────────────────────────────

  function buildHeaderElement(r: Restaurant, avg: number | null): Element {
    const tpl = document.getElementById(
      "tpl-restaurant-header",
    ) as HTMLTemplateElement;
    const div = (tpl.content.cloneNode(true) as DocumentFragment).querySelector(
      ".rh-card",
    )!;
    div.setAttribute("style", `view-transition-name: restaurant-${r.id}`);
    div.querySelector("h1")!.textContent = r.name;
    const dishes = getDishesByRestaurant(r.id);
    const pill = div.querySelector(".dish-count-pill");
    if (r.status === "pending") {
      const pendingSpan = document.createElement("span");
      pendingSpan.className = "pending-tag";
      pendingSpan.innerHTML = '<i class="bi bi-bookmark"></i> Pendiente';
      pill?.replaceWith(pendingSpan);
    } else {
      if (pill)
        pill.innerHTML = `<i class="bi bi-journal-text"></i> ${dishes.length} ${dishes.length === 1 ? "plato" : "platos"}`;
    }
    const badge = div.querySelector(".rating-badge")!;
    if (avg === null) {
      badge.className = "rating-badge badge-empty";
      badge.innerHTML = '<i class="bi bi-star"></i>';
    } else {
      badge.className = `rating-badge ${getRatingClass(avg)}`;
      badge.innerHTML = `<span class="rating-num">${avg}</span>`;
    }
    const notesEl = div.querySelector<HTMLElement>(".rh-notes");
    if (r.notes) {
      notesEl!.textContent = r.notes;
    } else {
      notesEl?.remove();
    }
    div
      .querySelector<HTMLButtonElement>(".rh-btn-edit-rh")!
      .addEventListener("click", () => {
        (window as any).restaurantForm.open("edit", r);
        // Cerrar menú
        div
          .querySelector<HTMLElement>(".rh-menu-popup")
          ?.classList.remove("active");
      });
    div
      .querySelector<HTMLButtonElement>(".rh-btn-delete-rh")!
      .addEventListener("click", () => {
        (window as any).confirmDialog.show(
          `¿Eliminar "${r.name}"? Se borrarán también sus platos.`,
          () => {
            deleteRestaurant(r.id);
            navigate("/");
          },
        );
        // Cerrar menú
        div
          .querySelector<HTMLElement>(".rh-menu-popup")
          ?.classList.remove("active");
      });

    // ─── Setup menú popup ─────────────────────────────────────────────────────
    const btnMenu = div.querySelector<HTMLButtonElement>(".rh-btn-menu")!;
    const menuPopup = div.querySelector<HTMLElement>(".rh-menu-popup")!;

    btnMenu.addEventListener("click", (e) => {
      e.stopPropagation();
      // Cerrar otros menús abiertos
      document.querySelectorAll(".rh-menu-popup.active").forEach((m) => {
        if (m !== menuPopup) {
          m.classList.remove("active");
        }
      });
      // Toggle menú actual
      menuPopup.classList.toggle("active");
    });

    // Cerrar menú al hacer click fuera
    const closeMenuOnClickOutside = (e: Event) => {
      const target = e.target as HTMLElement;
      if (!target.closest(".rh-menu")) {
        document.querySelectorAll(".rh-menu-popup.active").forEach((popup) => {
          popup.classList.remove("active");
        });
      }
    };
    document.addEventListener("click", closeMenuOnClickOutside);

    return div;
  }

  function buildDishCardElement(d: Dish): Element {
    const tpl = document.getElementById("tpl-dish-card") as HTMLTemplateElement;
    const article = (
      tpl.content.cloneNode(true) as DocumentFragment
    ).querySelector("article")!;
    article.setAttribute("data-id", d.id);
    article.querySelector("h4")!.textContent = d.name;
    const typeTagEl = article.querySelector<HTMLElement>(".dish-type-tag");
    if (d.typeId) {
      const typeName =
        getDishTypes().find((t) => t.id === d.typeId)?.name ?? null;
      if (typeName && typeTagEl) {
        typeTagEl.textContent = typeName;
      } else {
        typeTagEl?.remove();
      }
    } else {
      typeTagEl?.remove();
    }
    const notesEl = article.querySelector<HTMLElement>(".dish-notes");
    if (d.notes) {
      notesEl!.textContent = d.notes;
    } else {
      notesEl?.remove();
    }
    const badge = article.querySelector(".rating-badge")!;
    badge.className = `rating-badge ${getRatingClass(d.rating)}`;
    badge.innerHTML = `<span class="rating-num">${d.rating}</span>`;

    // ─── Setup menú popup ─────────────────────────────────────────────────────
    const btnMenu = article.querySelector<HTMLButtonElement>(".btn-menu")!;
    const menuPopup = article.querySelector<HTMLElement>(".menu-popup")!;

    btnMenu.addEventListener("click", (e) => {
      e.stopPropagation();
      // Cerrar otros menús abiertos
      document.querySelectorAll(".menu-popup.active").forEach((m) => {
        if (m !== menuPopup) {
          m.classList.remove("active");
        }
      });
      // Toggle menú actual
      menuPopup.classList.toggle("active");
    });

    // Cerrar menú al hacer click fuera
    const closeMenuOnClickOutside = (e: Event) => {
      const target = e.target as HTMLElement;
      if (!target.closest(".dish-menu")) {
        document.querySelectorAll(".menu-popup.active").forEach((popup) => {
          popup.classList.remove("active");
        });
      }
    };
    document.addEventListener("click", closeMenuOnClickOutside);

    // ─────────────────────────────────────────────────────────────────────────

    article
      .querySelector<HTMLButtonElement>(".btn-edit-dish")!
      .addEventListener("click", () => {
        (window as any).dishForm.open("edit", d.restaurantId, d);
        menuPopup.classList.remove("active");
      });
    article
      .querySelector<HTMLButtonElement>(".btn-delete-dish")!
      .addEventListener("click", () => {
        (window as any).confirmDialog.show(
          `¿Eliminar el plato "${d.name}"?`,
          () => {
            deleteDish(d.id);
            emit("dish:deleted", d.id);
          },
        );
        menuPopup.classList.remove("active");
      });
    return article;
  }

  function renderDishes(
    filtered: Dish[],
    totalCount: number,
    dishesListEl: HTMLElement,
    sortBarEl: HTMLElement | null,
  ) {
    if (sortBarEl) sortBarEl.hidden = totalCount < 2;
    if (filtered.length === 0) {
      const isFiltering = !!dishSearch || !!dishTypeFilter;
      dishesListEl.innerHTML = isFiltering
        ? `<div class="empty-state">
             <i class="bi bi-search"></i>
             <p>Sin resultados para la búsqueda.</p>
           </div>`
        : `<div class="empty-state">
             <i class="bi bi-egg-fried"></i>
             <p>Aún no hay platos registrados.</p>
             <p class="empty-hint">Agrega el primer plato con el botón de arriba.</p>
           </div>`;
      return;
    }
    dishesListEl.innerHTML = "";
    filtered.forEach((d) => dishesListEl.appendChild(buildDishCardElement(d)));
  }

  // ─── Funciones de render y wiring a nivel de módulo ───────────────────────
  // Consultan el DOM en cada llamada → inocuas en páginas sin estos elementos.

  function rerenderRestaurantePage() {
    const headerEl = document.getElementById("restaurant-header");
    const dishesListEl = document.getElementById("dishes-list");
    const sortBarEl = document.querySelector<HTMLElement>(".sort-bar");
    if (!headerEl || !dishesListEl || !currentRestaurant) return;

    const avg = getRestaurantAverage(currentRestaurant.id);
    const filtered = getFilteredSortedDishes(currentRestaurant.id);
    const total = getDishesByRestaurant(currentRestaurant.id).length;

    headerEl.replaceChildren(buildHeaderElement(currentRestaurant, avg));
    renderDishes(filtered, total, dishesListEl, sortBarEl);
    updateTypeSelect();
  }

  // ─── Listeners permanentes a nivel de módulo ──────────────────────────────

  document.addEventListener("dish:created", () => {
    if (!currentRestaurant) return;
    try {
      if (currentRestaurant.status === "pending") {
        const updated = markAsVisited(currentRestaurant.id);
        if (updated) {
          currentRestaurant = updated;
          // Actualizar backLink para que "Volver" lleve a visitados
          const bl = document.getElementById(
            "back-link",
          ) as HTMLAnchorElement | null;
          if (bl) bl.href = "/?tab=visitados";
          emit("restaurant:visited", updated);
        }
      }
    } catch (err) {
      console.error("[dish:created] markAsVisited error:", err);
    }
    rerenderRestaurantePage();
  });

  document.addEventListener("dish:updated", () => rerenderRestaurantePage());
  document.addEventListener("dish:deleted", () => {
    if (currentRestaurant?.status === "visited") {
      const remaining = getDishesByRestaurant(currentRestaurant.id);
      if (remaining.length === 0) {
        const updated = markAsPending(currentRestaurant.id);
        if (updated) {
          currentRestaurant = updated;
          const bl = document.getElementById(
            "back-link",
          ) as HTMLAnchorElement | null;
          if (bl) bl.href = "/?tab=pendientes";
          emit("restaurant:updated", updated);
        }
      }
    }
    rerenderRestaurantePage();
  });

  document.addEventListener("restaurant:updated", (e) => {
    try {
      const updated = (e as CustomEvent).detail as Restaurant;
      if (updated?.id === currentRestaurant?.id) currentRestaurant = updated;
    } catch (err) {
      console.error("[restaurant:updated] error:", err);
    }
    rerenderRestaurantePage();
  });

  // ─── PRE-RENDER en astro:after-swap ────────────────────────────────────────

  document.addEventListener("astro:after-swap", () => {
    const headerEl = document.getElementById("restaurant-header");
    if (!headerEl || !isCacheLoaded()) return;

    const id = new URLSearchParams(window.location.search).get("id") ?? "";
    const restaurant = getRestaurants().find((r) => r.id === id);
    if (!restaurant) return;

    const avg = getRestaurantAverage(restaurant.id);
    const filtered = getFilteredSortedDishes(restaurant.id);
    const total = getDishesByRestaurant(restaurant.id).length;

    headerEl.replaceChildren(buildHeaderElement(restaurant, avg));

    const dishesListEl = document.getElementById("dishes-list");
    const sortBarEl = document.querySelector<HTMLElement>(".sort-bar");
    if (!dishesListEl) return;

    renderDishes(filtered, total, dishesListEl, sortBarEl);
  });

  // ─── Init completo en astro:page-load ──────────────────────────────────────

  document.addEventListener("astro:page-load", async () => {
    const headerEl = document.getElementById("restaurant-header");
    if (!headerEl) return;

    const {
      data: { session },
    } = await supabase.auth.getSession();
    if (!session) {
      window.location.href = "/login";
      return;
    }
    await initCache(session.user.id);

    const id = new URLSearchParams(window.location.search).get("id") ?? "";
    currentRestaurant = getRestaurants().find((r) => r.id === id);

    const backLink = document.getElementById("back-link") as HTMLAnchorElement;
    if (backLink)
      backLink.href = `/?tab=${currentRestaurant?.status === "pending" ? "pendientes" : "visitados"}`;
    if (!currentRestaurant) {
      window.location.href = "/";
      return;
    }

    // ─── Sort UI ──────────────────────────────────────────────────────────────

    function updateDishSortUI() {
      document
        .querySelectorAll<HTMLButtonElement>(".sort-pill")
        .forEach((btn) => {
          const isActive = btn.dataset.field === dishSort.field;
          btn.classList.toggle("active", isActive);
          btn.querySelector("i")!.className = isActive
            ? `bi bi-arrow-${dishSort.dir === "asc" ? "up" : "down"}`
            : "bi bi-arrow-down-up";
        });
    }

    // ─── Cablear controles ────────────────────────────────────────────────────

    document
      .querySelectorAll<HTMLButtonElement>(".sort-pill")
      .forEach((btn) => {
        btn.onclick = () => {
          const field = btn.dataset.field as SortField;
          if (dishSort.field === field)
            dishSort.dir = dishSort.dir === "asc" ? "desc" : "asc";
          else {
            dishSort.field = field;
            dishSort.dir = field === "name" ? "asc" : "desc";
          }
          setSortState(dishSort);
          updateDishSortUI();
          rerenderRestaurantePage();
        };
      });

    document.getElementById("btn-add-dish")!.onclick = () =>
      (window as any).dishForm.open("create", currentRestaurant!.id);

    // ─── Búsqueda de platos ───────────────────────────────────────────────────

    const searchEl = document.getElementById(
      "dish-search",
    ) as HTMLInputElement | null;
    if (searchEl) {
      searchEl.value = dishSearch;
      searchEl.oninput = () => {
        dishSearch = searchEl.value;
        rerenderRestaurantePage();
      };
    }

    // ─── Filtro por tipo ──────────────────────────────────────────────────────

    const typeBtnEl = document.getElementById(
      "dish-type-btn",
    ) as HTMLButtonElement | null;
    const typeDropdownEl = document.getElementById(
      "dish-type-dropdown",
    ) as HTMLElement | null;

    if (typeBtnEl && typeDropdownEl) {
      updateTypeSelect();

      typeBtnEl.addEventListener("click", (e) => {
        e.stopPropagation();
        if (typeDropdownEl.hidden) {
          openDishTypeDropdown();
        } else {
          closeDishTypeDropdown();
        }
      });

      document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (
          !target.closest("#dish-type-btn") &&
          !target.closest("#dish-type-dropdown")
        ) {
          closeDishTypeDropdown();
        }
      });
    }

    // ─── Fix botón Atrás del navegador ────────────────────────────────────────
    // ViewTransitions no intercepta popstate en todos los casos; forzar navigate.

    const onPopState = () => navigate(window.location.href);
    window.addEventListener("popstate", onPopState);
    document.addEventListener(
      "astro:before-preparation",
      () => {
        window.removeEventListener("popstate", onPopState);
      },
      { once: true },
    );

    // ─── Render inicial con event wiring ─────────────────────────────────────

    updateDishSortUI();
    rerenderRestaurantePage();
  });
</script>
