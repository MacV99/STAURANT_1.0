---
import Layout1 from "../layouts/Layout1.astro";
---

<Layout1 title="Acceder · STAURANT" bare>
  <div class="auth-page">
    <div class="auth-card">
      <!-- Logo -->
      <div class="auth-logo">
        <a href="/"><img src="/img/logo2.png" alt="STAURANT" /></a>
      </div>

      <!-- Tabs -->
      <div class="auth-tabs">
        <button class="auth-tab active" data-tab="login">Iniciar sesión</button>
        <button class="auth-tab" data-tab="register">Registrarse</button>
      </div>

      <!-- Error global -->
      <p id="auth-error" class="auth-error" aria-live="polite"></p>

      <!-- Form login -->
      <form id="form-login" novalidate>
        <label>
          <span class="field-label">Email</span>
          <input
            type="email"
            id="login-email"
            autocomplete="email"
            placeholder="tu@email.com"
            required
          />
        </label>
        <label>
          <span class="field-label">Contraseña</span>
          <div class="pw-wrapper">
            <input
              type="password"
              id="login-password"
              autocomplete="current-password"
              placeholder="••••••••"
              required
            />
            <button
              type="button"
              class="pw-toggle"
              id="toggle-login-pw"
              aria-label="Mostrar contraseña"
            >
              <i class="bi bi-eye"></i>
            </button>
          </div>
        </label>
        <button type="submit" class="btn-primary" id="btn-login">Entrar</button>
      </form>

      <!-- Form register -->
      <form id="form-register" novalidate>
        <label>
          <span class="field-label">Nombre</span>
          <input
            type="text"
            id="reg-name"
            autocomplete="name"
            placeholder="Tu nombre"
          />
        </label>
        <label>
          <span class="field-label">Email</span>
          <input
            type="email"
            id="reg-email"
            autocomplete="email"
            placeholder="tu@email.com"
            required
          />
        </label>
        <label>
          <span class="field-label"
            >Contraseña <span class="field-hint">(mín. 6 caracteres)</span
            ></span
          >
          <div class="pw-wrapper">
            <input
              type="password"
              id="reg-password"
              autocomplete="new-password"
              placeholder="••••••••"
              required
            />
            <button
              type="button"
              class="pw-toggle"
              id="toggle-reg-pw"
              aria-label="Mostrar contraseña"
            >
              <i class="bi bi-eye"></i>
            </button>
          </div>
        </label>
        <button type="submit" class="btn-primary" id="btn-register"
          >Crear cuenta</button
        >
      </form>
    </div>
  </div>
</Layout1>

<style>
  .auth-page {
    width: 100%;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
  }

  .auth-card {
    background: var(--clr-white);
    border: solid 1px var(--clr-border);
    border-radius: 20px;
    padding: 32px 24px;
    width: 100%;
    max-width: 400px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    border: 1px solid var(--clr-border);
  }

  .auth-logo {
    display: flex;
    justify-content: center;
  }

  .auth-logo img {
    height: 52px;
    width: auto;
    border-radius: 10px;
  }

  .auth-tabs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--clr-white2);
    border-radius: 12px;
    padding: 4px;
    gap: 4px;
  }

  .auth-tab {
    padding: 9px;
    border-radius: 9px;
    border: none;
    background: transparent;
    color: var(--clr-text);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.3px;
    text-transform: none;
    cursor: pointer;
    transition: var(--transition);
  }

  .auth-tab.active {
    background: var(--clr-white);
    color: var(--clr-primary);
  }

  /* Oculto por defecto antes de que corra el JS */
  #form-register {
    display: none;
  }

  @keyframes formIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  form.form-visible {
    animation: formIn 0.22s ease both;
  }

  label {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .field-label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.8px;
    color: var(--clr-dark2);
    text-transform: uppercase;
  }

  .field-hint {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: var(--clr-text);
    opacity: 0.6;
    font-size: 0.75rem;
  }

  label input {
    border-radius: var(--border-radius);
    width: 100%;
  }

  /* Password toggle */
  .pw-wrapper {
    position: relative;
    display: flex;
  }

  .pw-wrapper input {
    flex: 1;
    padding-right: 44px;
    border-radius: var(--border-radius);
  }

  .pw-toggle {
    position: absolute;
    right: 0;
    top: 0;
    height: 100%;
    width: 42px;
    background: transparent;
    border: none;
    color: var(--clr-text);
    opacity: 0.45;
    font-size: 0.95rem;
    letter-spacing: 0;
    text-transform: none;
    padding: 0;
    border-radius: 0 var(--border-radius) var(--border-radius) 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.12s ease;
  }

  .pw-toggle:hover {
    opacity: 0.85;
    background: transparent;
  }

  .auth-error {
    font-size: 0.85rem;
    color: #c0392b;
    min-height: 1.2em;
    text-align: center;
  }

  .btn-primary {
    width: 100%;
    background: var(--clr-primary);
    color: var(--clr-white);
    border-color: var(--clr-primary);
    font-size: 0.9rem;
    padding: 12px;
    border-radius: 12px;
    margin-top: 4px;
    letter-spacing: 1px;
  }

  @media (hover: hover) {
    .btn-primary:hover {
      background: var(--clr-primary-dark);
      border-color: var(--clr-primary-dark);
    }

    .auth-tab:not(.active):hover {
      color: var(--clr-primary);
    }
  }

  @media (min-width: 768px) {
    .auth-card {
      padding: 40px 36px;
    }
  }
</style>

<script>
  import { navigate } from "astro:transitions/client";
  import { supabase } from "../lib/supabase.ts";

  // Si ya hay sesión, ir directo al inicio
  const {
    data: { session },
  } = await supabase.auth.getSession();
  if (session) {
    window.location.href = "/";
  }

  // ─── Tabs ──────────────────────────────────────────────────────────────────

  const tabBtns = document.querySelectorAll<HTMLButtonElement>(".auth-tab");
  const formLogin = document.getElementById("form-login") as HTMLFormElement;
  const formRegister = document.getElementById(
    "form-register",
  ) as HTMLFormElement;
  const errorEl = document.getElementById("auth-error")!;

  function showTab(tab: "login" | "register") {
    const active = tab === "login" ? formLogin : formRegister;
    const inactive = tab === "login" ? formRegister : formLogin;

    inactive.style.display = "none";
    inactive.classList.remove("form-visible");

    active.style.display = "flex";
    active.classList.remove("form-visible");
    void active.offsetHeight;
    active.classList.add("form-visible");

    tabBtns.forEach((btn) =>
      btn.classList.toggle("active", btn.dataset.tab === tab),
    );
    errorEl.textContent = "";
  }

  showTab("login");

  tabBtns.forEach((btn) => {
    btn.addEventListener("click", () =>
      showTab(btn.dataset.tab as "login" | "register"),
    );
  });

  // ─── Password toggles ──────────────────────────────────────────────────────

  function setupPwToggle(inputId: string, btnId: string) {
    const input = document.getElementById(inputId) as HTMLInputElement;
    const btn = document.getElementById(btnId) as HTMLButtonElement;
    btn.addEventListener("click", () => {
      const isHidden = input.type === "password";
      input.type = isHidden ? "text" : "password";
      btn.querySelector("i")!.className = isHidden
        ? "bi bi-eye-slash"
        : "bi bi-eye";
    });
  }

  setupPwToggle("login-password", "toggle-login-pw");
  setupPwToggle("reg-password", "toggle-reg-pw");

  // ─── Login ─────────────────────────────────────────────────────────────────

  formLogin.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.textContent = "";
    const email = (
      document.getElementById("login-email") as HTMLInputElement
    ).value.trim();
    const password = (
      document.getElementById("login-password") as HTMLInputElement
    ).value;
    const btn = document.getElementById("btn-login") as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = "Entrando...";

    const { error } = await supabase.auth.signInWithPassword({
      email,
      password,
    });
    if (error) {
      const msg = error.message.toLowerCase();
      errorEl.textContent = msg.includes("invalid login credentials")
        ? "Email o contraseña incorrectos."
        : msg.includes("email not confirmed")
          ? "Debes confirmar tu email antes de entrar. Revisa tu bandeja de entrada."
          : msg.includes("too many requests")
            ? "Demasiados intentos. Espera unos minutos."
            : "Error al iniciar sesión. Intenta de nuevo.";
      btn.disabled = false;
      btn.textContent = "Entrar";
      return;
    }
    navigate("/");
  });

  // ─── Register ──────────────────────────────────────────────────────────────

  formRegister.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.textContent = "";
    const name = (
      document.getElementById("reg-name") as HTMLInputElement
    ).value.trim();
    const email = (
      document.getElementById("reg-email") as HTMLInputElement
    ).value.trim();
    const password = (
      document.getElementById("reg-password") as HTMLInputElement
    ).value;
    const btn = document.getElementById("btn-register") as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = "Creando cuenta...";

    const { error } = await supabase.auth.signUp({
      email,
      password,
      options: { data: { full_name: name } },
    });
    if (error) {
      const msg = error.message.toLowerCase();
      errorEl.textContent =
        msg.includes("already registered") || msg.includes("user already")
          ? "Ya existe una cuenta con ese email."
          : msg.includes("password")
            ? "La contraseña debe tener al menos 6 caracteres."
            : msg.includes("invalid email")
              ? "El formato del email no es válido."
              : "Error al crear la cuenta. Intenta de nuevo.";
      btn.disabled = false;
      btn.textContent = "Crear cuenta";
      return;
    }
    navigate("/");
  });
</script>
