---
import Layout1 from "../layouts/Layout1.astro";
---

<Layout1 title="Perfil · STAURANT">
  <div class="profile-page">
    <a href="/" class="back-link">
      <i class="bi bi-arrow-left"></i> Volver
    </a>

    <div class="profile-card">
      <div class="profile-avatar" id="profile-avatar">
        <i class="bi bi-person-fill"></i>
      </div>

      <div class="profile-email-block">
        <span class="field-label">Email</span>
        <p id="profile-email" class="profile-email">—</p>
      </div>

      <form id="profile-form" novalidate>
        <label for="profile-name">
          <span class="field-label">Nombre</span>
          <input
            type="text"
            id="profile-name"
            autocomplete="name"
            placeholder="Tu nombre"
          />
        </label>
        <p id="profile-msg" class="profile-msg" aria-live="polite"></p>
        <button type="submit" class="btn-primary">Guardar cambios</button>
      </form>

      <div class="profile-divider"></div>

      <button id="btn-logout" class="btn-danger-outline">
        <i class="bi bi-box-arrow-right"></i> Cerrar sesión
      </button>
    </div>
  </div>
</Layout1>

<style>
  .profile-page {
    width: 100%;
    max-width: 480px;
    padding: 20px 16px 80px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--clr-primary);
    letter-spacing: 1px;
    width: fit-content;
    padding: 6px 0;
    transition: var(--transition);
  }

  .profile-card {
    background: #ffffff;
    border: solid 1px var(--clr-border);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    box-shadow: 0 4px 20px rgba(84, 107, 65, 0.08);
  }

  .profile-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--clr-white2);
    border: solid 2px var(--clr-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: var(--clr-primary);
    align-self: center;
  }

  .profile-email-block {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .field-label {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--clr-dark2);
    text-transform: uppercase;
  }

  .profile-email {
    font-size: 0.95rem;
    color: var(--clr-text);
    word-break: break-all;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  label {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  label input {
    border-radius: var(--border-radius);
    width: 100%;
  }

  .profile-msg {
    font-size: 0.85rem;
    min-height: 1.2em;
    color: var(--clr-primary);
    font-weight: 600;
  }

  .profile-msg.error {
    color: #c0392b;
  }

  .btn-primary {
    width: 100%;
    background: var(--clr-primary);
    color: white;
    border-color: var(--clr-primary);
    border-radius: 12px;
    padding: 12px;
    font-size: 0.9rem;
    letter-spacing: 1px;
  }

  .profile-divider {
    height: 1px;
    background: var(--clr-border);
  }

  .btn-danger-outline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: transparent;
    border: solid 1.5px #e8b4b4;
    color: #c0392b;
    border-radius: 12px;
    padding: 11px;
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: none;
    cursor: pointer;
    transition: var(--transition);
  }

  @media (hover: hover) {
    .back-link:hover {
      color: var(--clr-dark);
    }

    .btn-primary:hover {
      background: var(--clr-primary-dark);
      border-color: var(--clr-primary-dark);
    }

    .btn-danger-outline:hover {
      background: #fce8e8;
    }
  }

  @media (min-width: 768px) {
    .profile-page {
      padding: 28px 24px 80px;
    }

    .profile-card {
      padding: 36px 32px;
    }
  }
</style>

<script>
  import { supabase } from "../lib/supabase.ts";
  import { clearCache, initCache } from "../lib/data.ts";

  // ─── Auth guard ─────────────────────────────────────────────────────────────

  const { data: { session } } = await supabase.auth.getSession();
  if (!session) { window.location.href = "/login"; throw new Error("No auth"); }
  await initCache(session.user.id);

  // ─── Back link contextual ───────────────────────────────────────────────────

  const fromTab = new URLSearchParams(window.location.search).get("from") ?? "visitados";
  const backLinkEl = document.querySelector(".back-link") as HTMLAnchorElement;
  if (backLinkEl) backLinkEl.href = `/?tab=${fromTab}`;

  // ─── Cargar datos de perfil ─────────────────────────────────────────────────

  const user = session.user;
  const emailEl = document.getElementById("profile-email")!;
  const nameInput = document.getElementById("profile-name") as HTMLInputElement;
  const msgEl = document.getElementById("profile-msg")!;
  const avatarEl = document.getElementById("profile-avatar")!;

  emailEl.textContent = user.email ?? "";

  const { data: profile } = await supabase
    .from("profiles")
    .select("name")
    .eq("id", user.id)
    .single();

  if (profile?.name) {
    nameInput.value = profile.name;
    avatarEl.textContent = profile.name.charAt(0).toUpperCase();
  }

  // ─── Guardar nombre ─────────────────────────────────────────────────────────

  const form = document.getElementById("profile-form") as HTMLFormElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    msgEl.textContent = "";
    msgEl.classList.remove("error");

    const name = nameInput.value.trim();
    const btn = form.querySelector<HTMLButtonElement>("button[type='submit']")!;
    btn.disabled = true;
    btn.textContent = "Guardando...";

    const { error } = await supabase
      .from("profiles")
      .update({ name })
      .eq("id", user.id);

    if (error) {
      msgEl.textContent = "Error al guardar. Intenta de nuevo.";
      msgEl.classList.add("error");
    } else {
      msgEl.textContent = "¡Guardado correctamente!";
      if (name) avatarEl.textContent = name.charAt(0).toUpperCase();
    }

    btn.disabled = false;
    btn.textContent = "Guardar cambios";
  });

  // ─── Cerrar sesión ──────────────────────────────────────────────────────────

  document.getElementById("btn-logout")!.addEventListener("click", async () => {
    clearCache();
    await supabase.auth.signOut();
    window.location.href = "/login";
  });
</script>
