---
import Layout1 from "../layouts/Layout1.astro";
import TabBar from "../components/TabBar.astro";
import RestaurantForm from "../components/RestaurantForm.astro";
import ConfirmDialog from "../components/ConfirmDialog.astro";
---

<Layout1 title="STAURANT">
  <div class="app-page">
    <TabBar />

    <div class="sort-bar">
      <span class="sort-label">Ordenar</span>
      <div class="sort-pills">
        <button class="sort-pill" data-field="date"><i class="bi bi-arrow-down-up"></i> Fecha</button>
        <button class="sort-pill" data-field="name"><i class="bi bi-arrow-down-up"></i> Nombre</button>
        <button class="sort-pill" data-field="rating"><i class="bi bi-arrow-down-up"></i> Rating</button>
      </div>
    </div>

    <div id="tab-visitados" class="tab-content" role="tabpanel" hidden></div>
    <div id="tab-pendientes" class="tab-content" role="tabpanel" hidden></div>
  </div>

  <button id="btn-add-restaurant" class="fab" aria-label="Agregar restaurante">
    <i class="bi bi-plus-lg"></i>
  </button>

  <RestaurantForm />
  <ConfirmDialog />
</Layout1>

<style>
  .app-page {
    width: 100%;
    max-width: 1100px;
    padding: 20px 16px 100px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .tab-content {
    width: 100%;
  }

  @media (min-width: 768px) {
    .app-page {
      padding: 28px 24px 100px;
    }
  }
</style>

<script>
  import { supabase } from "../lib/supabase.ts";
  import {
    initCache, isCacheLoaded,
    getRestaurants,
    deleteRestaurant,
    getDishesByRestaurant,
    getRestaurantAverage,
  } from "../lib/data.ts";
  import { renderRestaurantCard } from "../scripts/store.ts";

  // ─── Sort state (persiste entre navegaciones en memoria de módulo) ──────────

  type SortField = "name" | "rating" | "date";
  type SortDir   = "asc" | "desc";
  const SORT_KEY = "staurant_sort_r";

  function getSortState(): { field: SortField; dir: SortDir } {
    try { return JSON.parse(localStorage.getItem(SORT_KEY) ?? "{}"); }
    catch { return { field: "date", dir: "desc" }; }
  }
  function setSortState(s: { field: SortField; dir: SortDir }) {
    localStorage.setItem(SORT_KEY, JSON.stringify(s));
  }

  let sortState = { field: "date" as SortField, dir: "desc" as SortDir, ...getSortState() };

  function sortRestaurants(list: ReturnType<typeof getRestaurants>) {
    return [...list].sort((a, b) => {
      let cmp = 0;
      if (sortState.field === "name") {
        cmp = a.name.localeCompare(b.name);
      } else if (sortState.field === "rating") {
        const ra = getRestaurantAverage(a.id) ?? -1;
        const rb = getRestaurantAverage(b.id) ?? -1;
        cmp = ra - rb;
      } else {
        cmp = new Date(a.createdAt).getTime() - new Date(b.createdAt).getTime();
      }
      return sortState.dir === "asc" ? cmp : -cmp;
    });
  }

  function getActiveTab(): "visitados" | "pendientes" {
    return (new URLSearchParams(window.location.search).get("tab") as "visitados" | "pendientes") ?? "visitados";
  }

  // ─── Sort UI ──────────────────────────────────────────────────────────────

  function updateSortUI() {
    document.querySelectorAll<HTMLButtonElement>(".sort-pill").forEach(btn => {
      const isActive = btn.dataset.field === sortState.field;
      btn.classList.toggle("active", isActive);
      btn.querySelector("i")!.className = isActive
        ? `bi bi-arrow-${sortState.dir === "asc" ? "up" : "down"}`
        : "bi bi-arrow-down-up";
    });
  }

  function buildListHTML(status: "visited" | "pending"): string {
    const all    = getRestaurants().filter(r => r.status === status);
    const sorted = sortRestaurants(all);
    if (sorted.length === 0) return `
      <div class="empty-state">
        <i class="bi bi-${status === "visited" ? "journal-check" : "bookmark"}"></i>
        <p>${status === "visited" ? "Aún no has registrado restaurantes visitados." : "No tienes restaurantes pendientes."}</p>
        ${status === "visited" ? '<p class="empty-hint">Agrega uno con el botón <strong>+</strong></p>' : ""}
      </div>`;
    return `<div class="cards-grid">${
      sorted.map(r => renderRestaurantCard(r, getRestaurantAverage(r.id), getDishesByRestaurant(r.id).length)).join("")
    }</div>`;
  }

  // ─── Funciones de render a nivel de módulo ────────────────────────────────
  // Consultan el DOM en cada llamada → inocuas en páginas que no tienen estos
  // elementos, y siempre operan sobre el DOM actual sin closures stale.

  function wireCardActions(container: HTMLElement, restaurants: ReturnType<typeof getRestaurants>) {
    container.querySelectorAll<HTMLElement>(".card-clickable").forEach((card) => {
      card.addEventListener("click", (e) => {
        if ((e.target as HTMLElement).closest("button")) return;
        const href = card.dataset.href;
        if (href) window.location.href = href;
      });
    });
    container.querySelectorAll<HTMLButtonElement>(".btn-edit-restaurant").forEach((btn) => {
      btn.addEventListener("click", () => {
        const r = restaurants.find((r) => r.id === btn.dataset.id);
        if (r) (window as any).restaurantForm.open("edit", r);
      });
    });
    container.querySelectorAll<HTMLButtonElement>(".btn-delete-restaurant").forEach((btn) => {
      btn.addEventListener("click", () => {
        const r = restaurants.find((r) => r.id === btn.dataset.id);
        (window as any).confirmDialog.show(
          `¿Eliminar "${r?.name}"? Se borrarán también sus platos.`,
          () => { deleteRestaurant(btn.dataset.id!); renderBoth(); }
        );
      });
    });
  }

  function renderList(status: "visited" | "pending", container: HTMLElement) {
    container.innerHTML = buildListHTML(status);
    const sorted = sortRestaurants(getRestaurants().filter(r => r.status === status));
    if (sorted.length > 0) wireCardActions(container, sorted);
  }

  function updateCounts() {
    const all = getRestaurants();
    const cv = document.getElementById("count-visitados");
    const cp = document.getElementById("count-pendientes");
    if (cv) cv.textContent = String(all.filter((r) => r.status === "visited").length);
    if (cp) cp.textContent = String(all.filter((r) => r.status === "pending").length);
  }

  function updateSortBarVisibility() {
    const sortBarEl = document.querySelector<HTMLElement>(".sort-bar");
    if (!sortBarEl) return;
    const status = getActiveTab() === "visitados" ? "visited" : "pending";
    sortBarEl.hidden = getRestaurants().filter((r) => r.status === status).length < 2;
  }

  function renderBoth() {
    const tv = document.getElementById("tab-visitados") as HTMLElement | null;
    const tp = document.getElementById("tab-pendientes") as HTMLElement | null;
    if (!tv || !tp) return;
    renderList("visited",  tv);
    renderList("pending",  tp);
    updateCounts();
    updateSortBarVisibility();
  }

  function activateTab(tab: "visitados" | "pendientes") {
    const tv = document.getElementById("tab-visitados") as HTMLElement | null;
    const tp = document.getElementById("tab-pendientes") as HTMLElement | null;
    if (!tv || !tp) return;
    tv.hidden = tab !== "visitados";
    tp.hidden = tab !== "pendientes";
    document.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach((btn) => {
      const active = btn.dataset.tab === tab;
      btn.classList.toggle("active", active);
      btn.setAttribute("aria-selected", String(active));
    });
    history.replaceState(null, "", `/?tab=${tab}`);
    updateSortBarVisibility();
  }

  // ─── Listeners permanentes a nivel de módulo ──────────────────────────────
  // Registrados una sola vez. renderBoth/activateTab son inocuas si no
  // estamos en la página principal (retornan early al no encontrar los divs).

  document.addEventListener("restaurant:created", () => { renderBoth(); activateTab("pendientes"); });
  document.addEventListener("restaurant:updated", () => renderBoth());
  document.addEventListener("restaurant:visited", () => renderBoth());

  // ─── PRE-RENDER en astro:after-swap ─────────────────────────────────────────

  document.addEventListener("astro:after-swap", () => {
    const tabVisitadosEl  = document.getElementById("tab-visitados")  as HTMLElement | null;
    const tabPendientesEl = document.getElementById("tab-pendientes") as HTMLElement | null;
    if (!tabVisitadosEl || !isCacheLoaded()) return;

    const activeTab = getActiveTab();

    tabVisitadosEl.innerHTML  = buildListHTML("visited");
    if (tabPendientesEl) tabPendientesEl.innerHTML = buildListHTML("pending");

    tabVisitadosEl.hidden  = activeTab !== "visitados";
    if (tabPendientesEl) tabPendientesEl.hidden = activeTab !== "pendientes";

    const sortBarEl = document.querySelector<HTMLElement>(".sort-bar");
    if (sortBarEl) {
      const status = activeTab === "visitados" ? "visited" : "pending";
      sortBarEl.hidden = getRestaurants().filter(r => r.status === status).length < 2;
    }

    const all = getRestaurants();
    const cv = document.getElementById("count-visitados");
    const cp = document.getElementById("count-pendientes");
    if (cv) cv.textContent = String(all.filter(r => r.status === "visited").length);
    if (cp) cp.textContent = String(all.filter(r => r.status === "pending").length);

    document.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach(btn => {
      const active = btn.dataset.tab === activeTab;
      btn.classList.toggle("active", active);
      btn.setAttribute("aria-selected", String(active));
    });

    updateSortUI();
  });

  // ─── Init por cada navegación (ViewTransitions + carga directa) ─────────────

  document.addEventListener("astro:page-load", async () => {
    const tabVisitadosEl = document.getElementById("tab-visitados");
    if (!tabVisitadosEl) return; // no estamos en la página principal

    // Auth (getSession lee localStorage — instantáneo)
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { window.location.href = "/login"; return; }
    await initCache(session.user.id);

    // ─── Cablear controles (onclick evita acumulación de listeners) ───────────

    document.querySelectorAll<HTMLButtonElement>(".sort-pill").forEach((btn) => {
      btn.onclick = () => {
        const field = btn.dataset.field as SortField;
        if (sortState.field === field) {
          sortState.dir = sortState.dir === "asc" ? "desc" : "asc";
        } else {
          sortState.field = field;
          sortState.dir = field === "rating" ? "desc" : "asc";
        }
        setSortState(sortState);
        updateSortUI();
        renderBoth();
      };
    });

    document.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach((btn) => {
      btn.onclick = () => activateTab(btn.dataset.tab as "visitados" | "pendientes");
    });

    const fabEl = document.getElementById("btn-add-restaurant")!;
    fabEl.onclick = () => (window as any).restaurantForm.open("create");

    // ─── Render inicial ───────────────────────────────────────────────────────

    updateSortUI();
    renderBoth();
    activateTab(getActiveTab());
  });
</script>
