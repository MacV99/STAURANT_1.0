---
import Navbar from "../components/navbar.astro";
---

<header class="flex-row">
  <a href="/" class="logo-link"><img src="/img/logo2.png" alt="img-logo" /></a>
  <Navbar />
  <a id="header-profile-btn" href="/perfil" class="profile-btn" aria-label="Perfil" hidden>
    <span id="header-avatar" class="profile-avatar-icon">
      <i class="bi bi-person-fill"></i>
    </span>
  </a>
</header>

<script>
  import { supabase } from "../lib/supabase.ts";

  const btn = document.getElementById("header-profile-btn") as HTMLAnchorElement;
  const avatarEl = document.getElementById("header-avatar")!;

  const { data: { session } } = await supabase.auth.getSession();
  if (session) {
    btn.hidden = false;
    const { data: profile } = await supabase
      .from("profiles")
      .select("name")
      .eq("id", session.user.id)
      .single();
    if (profile?.name) {
      avatarEl.textContent = profile.name.charAt(0).toUpperCase();
    }
  }
</script>

<style>
  header {
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 10px;
    background: rgba(255, 248, 236, 0.97);
    box-shadow: 0 4px 20px rgba(84, 107, 65, 0.12);
    border: solid 1px rgba(220, 204, 172, 0.6);
    border-radius: 20px;
    width: 95%;
    height: 72px;
    margin: 10px auto;
    padding: 12px 16px;
    transition: var(--transition);
    z-index: 100;
  }

  .logo-link {
    height: 100%;
    margin-right: auto;
    display: flex;
  }

  header img {
    height: 100%;
    width: auto;
    border-radius: 12px;
  }

  .profile-btn {
    height: auto;
    margin-left: 12px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .profile-avatar-icon {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--clr-white2);
    border: solid 1.5px var(--clr-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    color: var(--clr-primary);
    cursor: pointer;
    transition: var(--transition);
  }

  @media (hover: hover) {
    header:hover {
      background: rgba(255, 248, 236, 1);
    }

    .profile-avatar-icon:hover {
      background: var(--clr-border);
    }
  }

  @media (min-width: 768px) {
    header {
      backdrop-filter: blur(8px);
      background: rgba(255, 248, 236, 0.85);
      width: 98%;
    }
  }
</style>
