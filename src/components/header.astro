---
import Navbar from "../components/navbar.astro";
---

<header class="flex-row">
  <a href="/"><img src="/img/logo.jpg" alt="img-logo" /></a>
  <Navbar />
</header>

<style>
  header {
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 10px;
    background: rgba(250, 244, 251, 0.97);
    box-shadow: 0 4px 20px rgba(155, 71, 171, 0.12);
    border: solid 1px rgba(222, 200, 230, 0.6);
    border-radius: 20px;
    width: 95%;
    height: 72px;
    margin: 10px auto;
    padding: 12px 16px;
    transition: var(--transition);
    z-index: 100;
  }

  header a {
    height: 100%;
    margin-right: auto;
    display: flex;
  }

  header img {
    height: 100%;
    width: auto;
    border-radius: 12px;
  }

  @media (hover: hover) {
    header:hover {
      background: rgba(250, 244, 251, 1);
    }
  }

  @media (min-width: 768px) {
    header {
      backdrop-filter: blur(8px);
      background: rgba(250, 244, 251, 0.85);
      width: 98%;
    }
  }
</style>
