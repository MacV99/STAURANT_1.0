---
import Navbar from "../components/navbar.astro";
---

<header class="flex-row">
  <a href="/" class="logo-link"><img src="/img/logo2.png" alt="img-logo" /></a>
  <Navbar />
  <a
    id="header-profile-btn"
    href="/perfil"
    class="profile-btn"
    aria-label="Perfil"
    hidden
  >
    <span id="header-avatar" class="profile-avatar-icon">
      <i class="bi bi-person-fill"></i>
    </span>
  </a>
</header>

<script>
  import { supabase } from "../lib/supabase.ts";

  const PROFILE_CACHE_KEY = "staurant_profile_v1";

  // Pre-render inmediato desde caché (antes de la animación de ViewTransitions)
  document.addEventListener("astro:after-swap", () => {
    const btn = document.getElementById(
      "header-profile-btn",
    ) as HTMLAnchorElement | null;
    const avatarEl = document.getElementById("header-avatar");
    if (!btn || !avatarEl) return;
    try {
      const cached = JSON.parse(
        localStorage.getItem(PROFILE_CACHE_KEY) ?? "null",
      );
      if (!cached) return;
      btn.hidden = false;
      if (cached.name)
        avatarEl.textContent = cached.name.charAt(0).toUpperCase();
      const currentTab = new URLSearchParams(window.location.search).get("tab");
      btn.href = currentTab ? `/perfil?from=${currentTab}` : "/perfil";
    } catch {
      /* ignore */
    }
  });

  // Re-inicializar en cada navegación para que los elementos sean del DOM actual
  document.addEventListener("astro:page-load", async () => {
    const btn = document.getElementById(
      "header-profile-btn",
    ) as HTMLAnchorElement | null;
    const avatarEl = document.getElementById("header-avatar");
    if (!btn || !avatarEl) return;

    const {
      data: { session },
    } = await supabase.auth.getSession();
    if (!session) return;

    btn.hidden = false;
    // Pasar el tab activo al link de perfil para el back link contextual
    const currentTab = new URLSearchParams(window.location.search).get("tab");
    btn.href = currentTab ? `/perfil?from=${currentTab}` : "/perfil";

    // Leer avatar desde caché local (evita llamada a Supabase en cada navegación)
    try {
      const cached = JSON.parse(
        localStorage.getItem(PROFILE_CACHE_KEY) ?? "null",
      );
      if (cached?.name) {
        avatarEl.textContent = cached.name.charAt(0).toUpperCase();
        return;
      }
    } catch {
      /* ignore */
    }

    // Primera vez o caché sin nombre: cargar desde Supabase
    const { data: profile } = await supabase
      .from("profiles")
      .select("name")
      .eq("id", session.user.id)
      .single();
    if (profile?.name) {
      avatarEl.textContent = profile.name.charAt(0).toUpperCase();
    }
  });
</script>

<style>
  header {
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 10px;
    background: var(--clr-white);
    box-shadow: 0 4px 20px rgba(84, 107, 65, 0.12);
    border: solid 1px rgba(220, 204, 172, 0.6);
    border-radius: 20px;
    width: 95%;
    height: 72px;
    margin: 10px auto;
    padding: 12px 16px;
    transition: var(--transition);
    z-index: 100;
  }

  .logo-link {
    height: 100%;
    margin-right: auto;
    display: flex;
  }

  header img {
    height: 100%;
    width: auto;
    border-radius: 12px;
  }

  .profile-btn {
    height: auto;
    margin-left: 12px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .profile-avatar-icon {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--clr-white2);
    border: solid 1.5px var(--clr-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    color: var(--clr-primary);
    cursor: pointer;
    transition: var(--transition);
  }

  @media (hover: hover) {
    .profile-avatar-icon:hover {
      background: var(--clr-border);
    }
  }

  @media (min-width: 768px) {
    header {
      width: 98%;
    }
  }
</style>
