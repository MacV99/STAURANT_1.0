<div id="confirm-overlay" class="overlay" aria-modal="true" role="dialog">
  <div class="confirm-box">
    <div class="confirm-icon">
      <i class="bi bi-exclamation-triangle-fill"></i>
    </div>
    <p id="confirm-message">¿Estás seguro?</p>
    <div class="confirm-actions">
      <button id="confirm-cancel" class="boton2">Cancelar</button>
      <button id="confirm-ok" class="boton btn-danger">Eliminar</button>
    </div>
  </div>
</div>

<style>
  .confirm-box {
    background: var(--clr-white);
    border: solid 1px var(--clr-border);
    border-radius: 20px;
    padding: 32px 24px 28px;
    width: 90%;
    max-width: 360px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }

  .confirm-icon {
    font-size: 2.2rem;
    color: #b02a3a;
    line-height: 1;
  }

  #confirm-message {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--clr-dark);
    text-align: center;
    line-height: 1.5;
  }

  .confirm-actions {
    display: flex;
    gap: 10px;
    width: 100%;
    margin-top: 6px;
  }

  #confirm-cancel {
    flex: 1;
    background: var(--clr-white2);
    border-color: var(--clr-border);
    color: var(--clr-text);
    font-size: 0.85rem;
    letter-spacing: 0.5px;
  }

  #confirm-ok {
    flex: 1;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
  }
</style>

<script>
  // _onConfirm vive a nivel de módulo para persistir entre renders
  let _onConfirm: (() => void) | null = null;

  // Re-inicializar en cada navegación para que show/hide siempre
  // operen sobre los elementos del DOM ACTUAL (no los del swap anterior).
  document.addEventListener("astro:page-load", () => {
    const overlay   = document.getElementById("confirm-overlay");
    if (!overlay) return; // no está en esta página

    const msgEl     = document.getElementById("confirm-message")!;
    const cancelBtn = document.getElementById("confirm-cancel")!;
    const okBtn     = document.getElementById("confirm-ok")!;

    function show(message: string, onConfirm: () => void) {
      msgEl.textContent = message;
      _onConfirm = onConfirm;
      overlay.classList.add("is-open");
    }

    function hide() {
      overlay.classList.remove("is-open");
      _onConfirm = null;
    }

    // .onclick evita acumulación de listeners si el módulo re-ejecuta
    cancelBtn.onclick = hide;
    okBtn.onclick     = () => { _onConfirm?.(); hide(); };
    overlay.onclick   = (e) => { if (e.target === overlay) hide(); };

    // Actualizar API global con referencias frescas al DOM actual
    (window as any).confirmDialog = { show, hide };
  });
</script>
