<div id="dish-form-overlay" class="overlay" aria-modal="true" role="dialog">
  <div class="form-box">
    <div class="form-header">
      <h2 id="dish-form-title">Nuevo plato</h2>
      <button id="dish-form-close" class="btn-close boton2" aria-label="Cerrar">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>

    <form id="dish-form" novalidate>
      <input type="hidden" id="df-id" />
      <input type="hidden" id="df-restaurant-id" />

      <label for="df-name">
        <span class="label-text">Nombre del plato <span class="required">*</span></span>
        <input
          type="text"
          id="df-name"
          required
          placeholder="Bandeja paisa, Sushi roll..."
        />
      </label>

      <div class="rating-field">
        <span class="rating-label"
          >Calificación <span class="required">*</span></span
        >
        <div class="rating-row">
          <span class="range-min">1</span>
          <input
            type="range"
            id="df-rating"
            min="1"
            max="10"
            value="7"
            step="0.5"
          />
          <span class="range-max">10</span>
          <span id="df-rating-value" class="rating-value">7</span>
        </div>
      </div>

      <label for="df-notes">
        <span class="label-text">Notas</span>
        <textarea
          id="df-notes"
          rows="2"
          placeholder="Sabor, presentación, lo que quieras recordar..."
        ></textarea>
      </label>

      <p id="df-error" class="form-error" aria-live="polite"></p>

      <div class="form-footer">
        <button type="button" id="dish-form-cancel" class="boton2"
          >Cancelar</button
        >
        <button type="submit" class="boton">Guardar</button>
      </div>
    </form>
  </div>
</div>

<style>
  .form-box {
    background: var(--clr-white);
    border: solid 1px var(--clr-border);
    border-radius: 20px;
    padding: 24px 20px;
    width: 92%;
    max-width: 420px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .form-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .form-header h2 {
    font-size: 1.1rem;
    letter-spacing: 1px;
    color: var(--clr-dark);
  }

  .btn-close {
    padding: 6px 10px;
    border-radius: 10px;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  label {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--clr-dark2);
    text-transform: uppercase;
    gap: 0;
  }

  .label-text {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 3px;
    margin-bottom: 5px;
  }

  label input,
  label textarea {
    border-radius: var(--border-radius);
    width: 100%;
  }

  .rating-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .rating-label {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--clr-dark2);
    text-transform: uppercase;
  }

  .rating-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .rating-row input[type="range"] {
    flex: 1;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    accent-color: var(--clr-primary);
  }

  .range-min,
  .range-max {
    font-size: 0.8rem;
    color: var(--clr-text);
    font-weight: 600;
    min-width: 14px;
    text-align: center;
  }

  .rating-value {
    background: var(--clr-primary);
    color: white;
    font-weight: 700;
    font-size: 1rem;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .required {
    color: #e05050;
    font-weight: 700;
  }

  .optional {
    font-weight: 400;
    color: var(--clr-text);
    text-transform: none;
    letter-spacing: 0;
  }

  .form-error {
    font-size: 0.85rem;
    color: #e05050;
    min-height: 1.2em;
  }

  .form-footer {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    margin-top: 6px;
  }

  @media (min-width: 768px) {
    .form-box {
      padding: 28px 28px;
    }
  }
</style>

<script>
  import type { Dish } from "../lib/data.ts";
  import { createDish, updateDish, getDishesByRestaurant } from "../lib/data.ts";
  import { emit } from "../scripts/store.ts";

  // Re-inicializar en cada navegación para que open/close siempre
  // operen sobre los elementos del DOM ACTUAL (no los del swap anterior).
  document.addEventListener("astro:page-load", () => {
    const overlay = document.getElementById("dish-form-overlay");
    if (!overlay) return; // no está en esta página

    const form              = document.getElementById("dish-form") as HTMLFormElement;
    const titleEl           = document.getElementById("dish-form-title")!;
    const idInput           = document.getElementById("df-id") as HTMLInputElement;
    const restaurantIdInput = document.getElementById("df-restaurant-id") as HTMLInputElement;
    const nameInput         = document.getElementById("df-name") as HTMLInputElement;
    const ratingInput       = document.getElementById("df-rating") as HTMLInputElement;
    const ratingValue       = document.getElementById("df-rating-value")!;
    const notesInput        = document.getElementById("df-notes") as HTMLTextAreaElement;
    const errorEl           = document.getElementById("df-error")!;
    const closeBtn          = document.getElementById("dish-form-close")!;
    const cancelBtn         = document.getElementById("dish-form-cancel")!;

    function open(mode: "create" | "edit", restaurantId: string, data?: Dish) {
      errorEl.textContent = "";
      form.reset();
      ratingInput.value = "7";
      ratingValue.textContent = "7";
      restaurantIdInput.value = restaurantId;

      if (mode === "edit" && data) {
        titleEl.textContent = "Editar plato";
        idInput.value = data.id;
        nameInput.value = data.name;
        ratingInput.value = String(data.rating);
        ratingValue.textContent = String(data.rating);
        notesInput.value = data.notes;
      } else {
        titleEl.textContent = "Nuevo plato";
        idInput.value = "";
      }

      overlay.classList.add("is-open");
      nameInput.focus();
    }

    function close() {
      overlay.classList.remove("is-open");
    }

    // .onclick evita acumulación de listeners si el módulo re-ejecuta
    closeBtn.onclick  = close;
    cancelBtn.onclick = close;
    overlay.onclick   = (e) => { if (e.target === overlay) close(); };

    ratingInput.oninput = () => {
      ratingValue.textContent = ratingInput.value;
    };

    nameInput.oninput = () => {
      const pos = nameInput.selectionStart;
      nameInput.value = nameInput.value.toUpperCase();
      nameInput.setSelectionRange(pos, pos);
    };

    form.onsubmit = (e) => {
      e.preventDefault();
      errorEl.textContent = "";

      const name = nameInput.value.trim();
      if (!name) { errorEl.textContent = "El nombre del plato es obligatorio."; nameInput.focus(); return; }

      const restaurantId = restaurantIdInput.value;
      const id = idInput.value;

      const duplicate = getDishesByRestaurant(restaurantId).find(
        (d) => d.name.trim().toLowerCase() === name.toLowerCase() && d.id !== id
      );
      if (duplicate) { errorEl.textContent = "Ya existe un plato con ese nombre en este restaurante."; nameInput.focus(); return; }

      const rating = parseFloat(ratingInput.value);
      const notes = notesInput.value.trim();

      if (id) {
        const updated = updateDish(id, { name, rating, notes });
        if (updated) emit("dish:updated", updated);
      } else {
        emit("dish:created", createDish({ restaurantId, name, rating, notes }));
      }

      close();
    };

    // Actualizar API global con referencias frescas al DOM actual
    (window as any).dishForm = { open, close };
  });
</script>
