---
interface Props {
  score: number | null;
}
const { score } = Astro.props;

const cls = score === null
  ? "badge-empty"
  : score <= 4 ? "badge-low"
  : score <= 7 ? "badge-mid"
  : "badge-high";
---

{score === null
  ? <span class={`rating-badge ${cls}`}><i class="bi bi-star-fill"></i></span>
  : <span class={`rating-badge ${cls}`}><span class="rating-num">{score}</span></span>
}
