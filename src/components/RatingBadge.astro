---
interface Props {
  score: number | null;
}
const { score } = Astro.props;

let cls = "badge-empty";
let label = "—";
if (score !== null) {
  label = String(score);
  if (score <= 4) cls = "badge-low";
  else if (score <= 7) cls = "badge-mid";
  else cls = "badge-high";
}
---

<span class={`rating-badge ${cls}`}>{label}</span>
